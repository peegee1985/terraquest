{
  "expo": {
    "name": "TerraQuest",
    "slug": "terraquest",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "terraquest",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07111A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "package": "cz.terraquest.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "ACTIVITY_RECOGNITION",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "android.permission.health.READ_STEPS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TerraQuest používá polohu k odkrývání mapy během průzkumu.",
          "locationAlwaysAndWhenInUsePermission": "TerraQuest může pokračovat v ukládání aktivní trasy, když je telefon zamčený.",
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#07111A",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 92
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "disableAutoUpload": true
        }
      ],
      "expo-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 26
          }
        }
      ],
      "./plugins/withHealthConnectPermissionDelegate"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "privacyMode": "local-first",
      "progressionVersion": "v1",
      "eas": {
        "projectId": "cbb276cd-c61e-4ab2-b19f-1198d03987da"
      }
    },
    "owner": "peegee85"
  }
}
